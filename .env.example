# ============================================
# TELEGRAM BOT CONFIGURATION
# ============================================
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=YourBotUsername

# ============================================
# ADMIN CONFIGURATION
# Multiple admin IDs separated by comma
# ============================================
ADMIN_IDS=123456789,987654321

# ============================================
# DATABASE
# Use sqlite:///data/database.db for SQLite
# Use postgresql://user:pass@host/dbname for PostgreSQL
# ============================================
DATABASE_URL=sqlite:///data/database.db

# ============================================
# EXTERNAL LINKS
# ============================================
GAME_URL=https://example.com/game
EVENT_URL=https://example.com/events
DOWNLOAD_URL=https://example.com/download
PLAY_URL=https://example.com/play
CHANNEL_URL=https://t.me/your_channel
COMMUNITY_URL=https://t.me/your_community

# ============================================
# REWARD CONFIGURATION
# ============================================
POINTS_PER_CHECKIN=10
REFERRAL_REWARD=20
STREAK_7_REWARD=100
STREAK_30_REWARD=500
STREAK_100_REWARD=2000
STREAK_365_REWARD=10000

# ============================================
# WEBHOOK (for production deploy)
# Leave empty to use polling
# ============================================
WEBHOOK_URL=
WEBHOOK_PORT=8443

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_SECONDS=1
